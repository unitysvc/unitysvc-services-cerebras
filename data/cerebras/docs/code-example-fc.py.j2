import os
import requests
import json

url = f"{os.getenv('SERVICE_BASE_URL')}/chat/completions"

headers = {
    "Authorization": f"Bearer {os.getenv('UNITYSVC_API_KEY')}",
    "Content-Type": "application/json"
}

data = {
    "model": "{{offering.name}}",
    "messages": [
        {"role": "user", "content": "What's the weather in Houston?"}
    ],
    "tools": [
        {
            "type": "function",
            "function": {
                "name": "get_weather",
                "description": "Get current weather for a city",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "city": {
                            "type": "string",
                            "description": "Name of the city"
                        }
                    },
                    "required": ["city"]
                }
            }
        }
    ],
    "tool_choice": "auto"
}

response = requests.post(url, headers=headers, json=data)
result = response.json()

print(json.dumps(result, indent=2))